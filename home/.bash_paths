#
# ~/.bash_paths
#

# In order to avoid reappended variables, it must be sourced
# from "profile" initialization files only.
# Don't source it from rc files.


## Paths

export PROJECTS=~/projs

# gcc with color (cc c++ gcc g++)
if [[ -d /usr/lib/colorgcc/bin ]]; then
        export PATH="/usr/lib/colorgcc/bin:$PATH"
fi
