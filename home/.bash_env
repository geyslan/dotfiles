#
# ~/.bash_env
#

## Environment variables

export PROJS=~/projs
export PROJSBIN="$PROJS/bin"
export WALLDIR="/data/pics/wallpapers"
export LOCKWALL="/tmp/lock-wallpaper.png"

## Paths

# Insert paths
insertpath () {
	case ":$PATH:" in
		*:"$1":*)
			;;
		"")
			;;
		*)
			PATH="$1${PATH:+:$PATH}"
	esac
}

# Append paths
appendpath () {
	case ":$PATH:" in
		*:"$1":*)
			;;
		"")
			;;
		*)
			PATH="${PATH:+$PATH:}$1"
	esac
}


# colorgcc
[[ -d /usr/lib/colorgcc/bin ]] && insertpath '/usr/lib/colorgcc/bin'
appendpath $PROJSBIN
unset insertpath
unset appendpath
