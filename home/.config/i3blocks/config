# i3blocks config file
#
# Please see man i3blocks for a complete reference!
# The man page is also hosted at http://vivien.github.io/i3blocks
#
# List of valid properties:
#
# align
# color
# background
# border
# command
# full_text
# instance
# interval
# label
# min_width
# name
# separator
# separator_block_width
# short_text
# signal
# urgent

# Global properties
#
# The top properties below are applied to every block, but can be overridden.
# Each block command defaults to the script name to avoid boilerplate.
command=/usr/lib/i3blocks/$BLOCK_NAME
separator_block_width=17
separator=false
#full_text=〉
full_text=-
align=center
color=#a3be8c
markup=none
border_top=0
border_bottom=1
border_right=0
border_left=0
border=#004477

# Battery indicator
#
# The battery instance defaults to 0.
#[battery]
#label=BAT
#label=⚡
#command=/usr/lib/i3blocks/battery; [[ -z "${BLOCK_BUTTON}" ]] || gnome-control-center power
#instance=1
#interval=30
#color=#dddddd
#separator=false
#[separator]
#border_bottom=0

# Network interface monitoring
#
# If the instance is not specified, use the interface used for default route.
# The address can be forced to IPv4 or IPv6 with -4 or -6 switches.
[iface]
command=/usr/lib/i3blocks/iface; [[ -z "${BLOCK_BUTTON}" ]] || gnome-nettool
#instance=wlan0
color=#2c9df4
interval=10
#separator=false

#[wifi]
#label=
#command=/usr/lib/i3blocks/wifi; [[ -z "${BLOCK_BUTTON}" ]] || kitty wavemon
#instance=wlp2s0
#color=#dddddd
#interval=10
#separator=false

[bandwidth]
command=/usr/lib/i3blocks/bandwidth; [[ -z "${BLOCK_BUTTON}" ]] || kitty sudo iftop -P
#instance=eth0
interval=5
#background=#2f2f2f
color=#dddddd
#separator=false
[separator]
border_bottom=0

# CPU usage
#
# The script may be called with -w and -c switches to specify thresholds,
# see the script for details.
[cpu_usage]
label=
command=/usr/lib/i3blocks/cpu_usage; [[ -z "${BLOCK_BUTTON}" ]] || gnome-system-monitor --show-resources-tab
interval=10
#min_width=CPU: 100.00%
separator=false
color=#2c9df4
separator=false

[load_average]
label= 
command=/usr/lib/i3blocks/load_average; [[ -z "${BLOCK_BUTTON}" ]] || kitty htop -s PERCENT_CPU
interval=10
color=#dddddd
separator=false

[temperature]
label=
command=echo "$(( $(cat /sys/class/thermal/thermal_zone0/temp) / 1000 ))°C"; [[ -z "${BLOCK_BUTTON}" ]] || xsensors
interval=10
separator=false
color=#dddddd
[separator]
border_bottom=0

# Memory usage
#
# The type defaults to "mem" if the instance is not specified.
#[memory]
#label=MEM
#separator=false
#interval=30
#background=#5f5f5f
#color=#dfdfdf

#[memory]
#label=SWAP
#instance=swap
#separator=false
#interval=30

# Disk usage
#
# The directory defaults to $HOME if the instance is not specified.
# The script may be called with a optional argument to set the alert
# (defaults to 10 for 10%).
[disk]
label=
command=/usr/lib/i3blocks/disk; [[ -z "${BLOCK_BUTTON}" ]] || nautilus ~/
#instance=/mnt/data
interval=30
color=#2c9df4
separator=false

[disk]
label=
command=/usr/lib/i3blocks/disk; [[ -z "${BLOCK_BUTTON}" ]] || nautilus /
instance=/
interval=30
#background=#2f2f2f
color=#dddddd
[separator]
border_bottom=0

# Volume indicator
#
# The first parameter sets the step (and units to display)
# The second parameter overrides the mixer selection
# See the script for details.
[volume]
label=♪
instance=Master
#instance=PCM
interval=1
signal=10
command=/usr/lib/i3blocks/volume; [[ -z "${BLOCK_BUTTON}" ]] || pavucontrol
[separator]
border_bottom=0

# Date Time
#
[date]
label=
command=date '+%d-%m-%Y'; [[ -z "${BLOCK_BUTTON}" ]] || gnome-calendar
color=#2c9df4
interval=1
separator=false

[time]
command=date '+%H:%M'; [[ -z "${BLOCK_BUTTON}" ]] || gnome-clocks
background=#2a69b4
color=#ffffff
interval=1
border_top=1
border_bottom=1
border_right=1
border_left=1
border=#00aaff
